{
  "name": "ii3230-end2end",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "engines": {
    "node": ">=20.17.0"
  },
  "scripts": {
    "build": "tsc -b packages/shared apps/api",
    "bob:lan": "tsx scripts/run-bob.ts",
    "build:shared": "npm run build --workspace @ii3230/shared",
    "keys:generate:local": "tsx scripts/generate-local-keys.ts",
    "dev": "npm run build:shared && npm run dev --workspace @ii3230/api",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "npm run build:shared && vitest run",
    "test:e2e:local": "tsx scripts/test-e2e-local.ts",
    "test:e2e:tamper": "tsx scripts/test-e2e-tamper.ts",
    "test:all": "npm run test && npm run test:e2e:local && npm run test:e2e:tamper",
    "test:watch": "npm run build:shared && vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
